#include <stdio.h>

int main()
{
    int a[] = {2,4,6,8,10,12,14,18};
    int n = 8;

    int min = a[0];
    int max = a[0];

    for(int i=1;i<n;i++)
    {
        if(a[i] < min)
            min = a[i];

        if(a[i] > max)
            max = a[i];
    }

    printf("Min = %d\n", min);
    printf("Max = %d\n", max);

    return 0;
}
OUTPUT
Min = 2
Max = 18
