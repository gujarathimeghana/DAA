#include <stdio.h>
#include <string.h>

int main() {
    char haystack[] = "sadbutsad";
    char needle[] = "sad";

    int n = strlen(haystack);
    int m = strlen(needle);
    int i, j, found = -1;

    for(i = 0; i <= n - m; i++) {
        for(j = 0; j < m; j++) {
            if(haystack[i + j] != needle[j])
                break;
        }
        if(j == m) {
            found = i;
            break;
        }
    }

    printf("Output: %d", found);
    return 0;
}
Output: 0
