#include <stdio.h>

void printArray(int a[], int n)
{
    for(int i=0;i<n;i++)
        printf("%d ",a[i]);
    printf("\n");
}

int partition(int a[], int low, int high)
{
    int pivot = a[low];
    int i = low+1;
    int j = high;
    int temp;

    while(1)
    {
        while(i<=high && a[i]<=pivot)
            i++;

        while(a[j]>pivot)
            j--;

        if(i<j)
        {
            temp=a[i];
            a[i]=a[j];
            a[j]=temp;
        }
        else
            break;
    }

    temp=a[low];
    a[low]=a[j];
    a[j]=temp;

    return j;
}

void quicksort(int a[], int low, int high, int n)
{
    if(low<high)
    {
        int p = partition(a,low,high);
        printArray(a,n);

        quicksort(a,low,p-1,n);
        quicksort(a,p+1,high,n);
    }
}

int main()
{
    int a[] = {10,16,8,12,15,6,3,9,5};
    int n = 9;

    quicksort(a,0,n-1,n);

    printf("Sorted Array: ");
    printArray(a,n);

    return 0;
}
OUTPUT
3 5 6 8 9 10 12 15 16
