#include <stdio.h>

void printArray(int a[], int n)
{
    for(int i=0;i<n;i++)
        printf("%d ",a[i]);
    printf("\n");
}

void quickSort(int a[], int low, int high, int n)
{
    if(low<high)
    {
        int i=low,j=high;
        int pivot=a[(low+high)/2];

        while(i<=j)
        {
            while(a[i]<pivot) i++;
            while(a[j]>pivot) j--;

            if(i<=j)
            {
                int temp=a[i];
                a[i]=a[j];
                a[j]=temp;
                i++;
                j--;
            }
        }

        printArray(a,n);

        quickSort(a,low,j,n);
        quickSort(a,i,high,n);
    }
}

int main()
{
    int a[]={19,72,35,46,58,91,22,31};
    int n=8;

    quickSort(a,0,n-1,n);

    printf("Sorted array: ");
    printArray(a,n);

    return 0;
}
