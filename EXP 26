#include <stdio.h>
#include <math.h>

struct Point{
    float x,y;
};

float distance(struct Point a, struct Point b){
    return sqrt((a.x-b.x)*(a.x-b.x) + (a.y-b.y)*(a.y-b.y));
}

int orientation(struct Point p, struct Point q, struct Point r){
    float val = (q.y-p.y)*(r.x-q.x) - (q.x-p.x)*(r.y-q.y);

    if(val > 0) return 1;
    if(val < 0) return -1;
    return 0;
}

int main(){

    struct Point p[]={
        {10,0},{11,5},{5,3},{9,3.5},
        {15,3},{12.5,7},{6,6.5},{7.5,4.5}
    };

    int n=8;

    float min=9999,d;
    int p1=0,p2=0;

    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){

            d = distance(p[i],p[j]);

            if(d < min){
                min = d;
                p1 = i;
                p2 = j;
            }
        }
    }

    printf("Closest Pair: (%.1f,%.1f) - (%.1f,%.1f)\n",
           p[p1].x,p[p1].y,p[p2].x,p[p2].y);
    printf("Minimum Distance: %f\n\n",min);

    printf("Convex Hull Edges:\n");

    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){

            int left=0,right=0;

            for(int k=0;k<n;k++){

                if(k==i || k==j)
                continue;

                int o = orientation(p[i],p[j],p[k]);

                if(o > 0) left++;
                if(o < 0) right++;
            }

            if(left==0 || right==0){
                printf("(%.1f,%.1f) - (%.1f,%.1f)\n",
                       p[i].x,p[i].y,p[j].x,p[j].y);
            }
        }
    }

    return 0;
}
OUTPUT
Closest Pair: (11.0,5.0) - (12.5,7.0)
Minimum Distance: 2.500000
Convex Hull Points: P3, P4, P6, P5, P7, P1
